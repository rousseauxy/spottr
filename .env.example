# ─── Usenet (required) ────────────────────────────────────────────────────────
NNTP_HOST=news.example.com
NNTP_PORT=563
NNTP_TLS=true
NNTP_USER=youruser
NNTP_PASS=yourpassword
NNTP_MAX_CONNS=4

# ─── Sync ─────────────────────────────────────────────────────────────────────
# How often to poll for new spots
SYNC_INTERVAL=15m
# How many articles to look back on first run
SYNC_LOOKBACK=500000

# ─── SABnzbd (optional) ───────────────────────────────────────────────────────
SAB_HOST=sabnzbd
SAB_PORT=8080
SAB_API_KEY=
SAB_TLS=false

# ─── Auth (optional) ──────────────────────────────────────────────────────────
# Set a password to enable the built-in login screen.
# Leave empty (or omit) when using an external auth proxy such as Authentik.
APP_PASSWORD=

# How long a session cookie stays valid (default: 24h)
SESSION_DURATION=24h

# ─── Content ──────────────────────────────────────────────────────────────────
# Show 18+ categories (default: false)
ALLOW_ADULT=false

# ─── Newznab API key (optional) ───────────────────────────────────────────────
# Used by Prowlarr / Sonarr / Radarr. Auto-generated on startup if not set.
# Check the container logs on first run to see the generated key.
API_KEY=

# ─── Misc ─────────────────────────────────────────────────────────────────────
TZ=Europe/Brussels
DB_PATH=/data/spottr.db
LISTEN_ADDR=:8080
